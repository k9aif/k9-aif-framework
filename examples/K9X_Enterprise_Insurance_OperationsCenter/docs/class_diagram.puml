@startuml K9X_Enterprise_Insurance_OperationsCenter

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 13
skinparam linetype ortho
skinparam groupInheritance 2

' ─────────────────────────────────────────────
' K9 Framework base classes (external)
' ─────────────────────────────────────────────
package "K9-AIF Framework (external)" #LightGray {
    abstract class BaseAgent {
        +layer: str
        +config: dict
        +execute(payload): dict
    }

    abstract class BaseOrchestrator {
        +_initialize()
        +execute_flow(payload): dict
    }

    abstract class BaseRouter {
        +route(event_type, payload): dict
        +supported_event_types(): list
    }

    abstract class BaseSquad {
        +name: str
        +agents: dict
        +run(request, context): dict
    }

    abstract class K9ModelRouter {
        +invoke(request): InferenceResponse
        +route(request): RouteDecision
    }

    class K9EventBus
    class InferenceRequest
    class InferenceResponse
    class RouteDecision
}

' ─────────────────────────────────────────────
' Pydantic Models
' ─────────────────────────────────────────────
package "api / models" #FEFECE {
    class EOCEvent {
        +event_type: str
        +event_id: str
        +correlation_id: str
    }

    class ClaimSubmittedEvent {
        +event_type = "claim_submitted"
        +claim_id: str
        +claimant_id: str
        +policy_id: str
        +claim_type: str
        +amount_claimed: float
        +notes: str
        +is_repeat_claimant: bool
    }

    class DocumentReceivedEvent {
        +event_type = "document_received"
        +document_id: str
        +claim_id: str
        +claimant_id: str
        +filename: str
        +file_type: str
        +raw_text: str
        +file_path: str
    }

    class FraudSignalEvent {
        +event_type = "fraud_signal_raised"
        +alert_id: str
        +alert_source: str
        +claimant_id: str
        +claim_id: str
        +description: str
        +amount_claimed: float
        +severity: str
    }

    class PolicyChangeEvent {
        +event_type = "policy_change_requested"
        +policy_id: str
        +claimant_id: str
        +change_type: str
        +change_description: str
        +notes: str
    }

    class CatastropheAlertEvent {
        +event_type = "catastrophe_alert_issued"
        +alert_id: str
        +alert_description: str
        +estimated_exposure: float
        +affected_regions: list
        +severity: str
    }

    class CustomerInteractionEvent {
        +event_type = "customer_interaction_logged"
        +interaction_id: str
        +customer_id: str
        +policy_id: str
        +interaction_type: str
        +customer_message: str
        +channel: str
    }

    class AuditQueryRequest {
        +query_correlation_id: str
        +query_event_id: str
        +query_agent_name: str
        +query_event_type: str
        +limit: int
    }

    class EscalationResolveRequest {
        +operator_id: str
        +resolution: str
        +resolution_notes: str
    }

    class EOCEventResponse {
        +status: str
        +event_id: str
        +correlation_id: str
        +squad_id: str
        +final_decision: str
        +confidence: float
        +escalated: bool
        +ticket_id: str
        +audit_id: str
        +details: dict
    }

    class TraceStep {
        +step: int
        +component: str
        +layer: str
        +status: str
        +message: str
        +final: bool
        +agent_yaml: dict
        +model_routing: dict
        +governance_detail: dict
        +latency_ms: float
        +tools: list
        +agent_result: dict
    }

    class ScenarioRunResponse {
        +event_type: str
        +event_id: str
        +correlation_id: str
        +squad_id: str
        +trace: list[TraceStep]
        +result: dict
        +error: str
    }
}

EOCEvent <|-- ClaimSubmittedEvent
EOCEvent <|-- DocumentReceivedEvent
EOCEvent <|-- FraudSignalEvent
EOCEvent <|-- PolicyChangeEvent
EOCEvent <|-- CatastropheAlertEvent
EOCEvent <|-- CustomerInteractionEvent
ScenarioRunResponse *-- TraceStep

' ─────────────────────────────────────────────
' Router layer
' ─────────────────────────────────────────────
package "router" #E8F4FD {
    class EOCRouter {
        -_broker
        -_buses: dict[str, K9EventBus]
        +route(event_type, payload): dict
        +supported_event_types(): list
        +close()
    }

    class EOCModelRouter {
        +GUARDIAN_REQUIRED_TASKS: set
        +COST_SENSITIVE_TASKS: set
        -_sse_callback
        +invoke(request): InferenceResponse
        +route(request): RouteDecision
    }
}

BaseRouter <|-- EOCRouter
K9ModelRouter <|-- EOCModelRouter
EOCRouter o-- K9EventBus

