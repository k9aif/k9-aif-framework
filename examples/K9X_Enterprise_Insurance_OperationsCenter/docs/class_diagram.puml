' ─────────────────────────────────────────────
' Agents
' ─────────────────────────────────────────────
package "agents" #F5EEFB {
    class ClaimsTriageAgent {
        +layer = "EOC ClaimsTriage SBB"
        +REQUIRED_CLAIM_FIELDS: list
        +PRIORITY_THRESHOLDS: dict
        +execute(payload): dict
        -_score_priority(amount): str
        -_check_coverage(payload): bool
        -_upsert_claim(payload, result)
    }

    class AdjudicationAgent {
        +layer = "EOC Adjudication SBB"
        +execute(payload): dict
        -_parse_response(raw): dict
        -_persist_decision(payload, result)
    }

    class GuardAgent {
        +layer = "EOC Guard SBB"
        +PII_PATTERNS: list
        +execute(payload): dict
        -_extract_text(payload): str
        -_pattern_scan(text): list
        -_mask_pii(text, findings): str
        -_parse_guardian_output(output, findings): dict
    }

    class FraudDetectionAgent {
        +layer = "EOC FraudDetection SBB"
        +FRAUD_SIGNAL_KEYWORDS: list
        +RISK_SCORE_HIGH = 0.8
        +RISK_SCORE_MEDIUM = 0.5
        +execute(payload): dict
        -_apply_rule_signals(payload): list
        -_score_from_rules(signals): float
        -_build_context(payload): str
        -_parse_response(raw): dict
    }

    class DocumentExtractorAgent {
        +layer = "EOC DocumentExtractor SBB"
        -_tesseract_available: bool
        +execute(payload): dict
        -_check_tesseract(): bool
        -_ocr_extract(file_path): str
        -_parse_json_output(raw): dict
    }

    class GraphSyncAgent {
        +layer = "EOC GraphSync SBB"
        -_graph_enabled: bool
        -_driver
        +execute(payload): dict
        -_connect_neo4j()
        -_build_operations(payload, event_type): list
        -_execute_operations(operations)
    }

    class AuditAgent {
        +layer = "EOC Audit SBB"
        -_pg_cfg: dict
        +execute(payload): dict
        -_write_audit(payload)
        -_query_audit(payload): list
        -_persist_entry(entry)
        -_resolve_confidence(payload): float
        -_resolve_disposition(payload): str
        -_resolve_governance_checks(payload): dict
    }

    class EscalationAgent {
        +layer = "EOC Escalation SBB"
        +DEFAULT_CONFIDENCE_THRESHOLD = 0.75
        -_threshold: float
        +execute(payload): dict
        -_build_reason(confidence, guard_failed, force): str
        -_persist(ticket)
        -_derive_priority(confidence, guard_failed): str
        -_safe_context(payload): dict
    }
}

