# ============================================================
# K9-AIF EOC — Environment Variables
# ============================================================
# STEP 1: Copy this file and rename it to .env
#         cp env-example .env
#
# STEP 2: Replace placeholder values with your actual settings
#
# STEP 3: Never commit .env — it is gitignored
# ============================================================

OLLAMA_BASE_URL=http://your-ollama-host:11434

POSTGRES_HOST=your-postgres-host
POSTGRES_USER=postgres
POSTGRES_DB=eoc
K9_PG_PASSWORD=your_postgres_password

NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

KAFKA_BROKER=your-kafka-host:9092

REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# K9_ENV controls governance enforcement
# development | test | staging | production
K9_ENV=development
