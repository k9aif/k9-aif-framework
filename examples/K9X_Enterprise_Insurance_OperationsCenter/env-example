# EOC Environment Variables
# Copy this file to .env and fill in the real values.
# Never commit .env to version control.

# PostgreSQL credentials
K9_PG_PASSWORD=your_postgres_password_here

# Neo4j credentials
NEO4J_URI=bolt://192.168.1.98:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Optional: K9_ENV controls governance enforcement
# development | test | staging | production
K9_ENV=development
